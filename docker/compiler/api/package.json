{
  "name": "miden-sourcify-compiler-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "node --import=tsx server.ts",
    "compose:up": "docker compose -f ../../docker-compose.yml up -d --build --wait compiler",
    "compose:down": "docker compose -f ../../docker-compose.yml down",
    "test": "npm run compose:up && vitest run; e=$?; npm run compose:down; exit $e",
    "test:watch": "npm run compose:up && vitest"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
